<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.shape.Circle?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="controller.PomodoroController" spacing="10" style="-fx-padding: 20;" alignment="TOP_LEFT">
    <Button text="&lt; VOLVER" onAction="#volver" />
    
    <HBox spacing="30" alignment="CENTER" VBox.vgrow="ALWAYS">
        <VBox spacing="20" alignment="CENTER" HBox.hgrow="ALWAYS">
            <Label text="TEMPORIZADOR" styleClass="title-label"/>
            
            <ComboBox fx:id="cbMateriaActiva" promptText="SELECCIONAR MATERIA" prefWidth="250"/>
            
            <StackPane VBox.vgrow="ALWAYS">
                <Circle fx:id="circleTimer" radius="100" styleClass="pomodoro-circle"/>
                <Label fx:id="lblTiempo" text="25:00" style="-fx-font-size: 32px; -fx-text-fill: #FDE047;"/>
            </StackPane>
            
            <HBox spacing="15" alignment="CENTER">
                <Button fx:id="btnIniciar" text="[ INICIAR ]" onAction="#iniciarTimer" styleClass="action-button"/>
                <Button fx:id="btnPausar" text="[ PAUSAR ]" onAction="#pausarTimer" />
                <Button fx:id="btnReset" text="[ RESET ]" onAction="#resetTimer" />
                <Button text="[ TIEMPO ]" onAction="#editarTiempo" />
            </HBox>
        </VBox>

        <VBox spacing="10" prefWidth="250" HBox.hgrow="NEVER" style="-fx-padding: 15; -fx-border-color: #4A4262; -fx-border-width: 2px;">
            <Label text="HISTORIAL" styleClass="title-label" style="-fx-font-size: 14px;"/>
            <ListView fx:id="listHistorial" VBox.vgrow="ALWAYS"/>
        </VBox>
    </HBox>
</VBox>
